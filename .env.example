# ─────────────────────────────────────────────────────────────────
#  The-Pool V2 — Environment Variables Template
#  cp .env.example .env  →  fill in YOUR values  →  NEVER commit .env
#  Deployment uses a Ledger hardware wallet (no private key needed).
#  Run:  forge script script/DeployVaultV2.s.sol --rpc-url $ARBITRUM_RPC_URL --ledger ...
# ─────────────────────────────────────────────────────────────────

# ── RPC ───────────────────────────────────────────────────────────
# Arbitrum One mainnet
ARBITRUM_RPC_URL=https://arb1.arbitrum.io/rpc

# Arbitrum Sepolia testnet (free ETH: https://faucet.quicknode.com/arbitrum/sepolia)
ARBITRUM_TESTNET_RPC_URL=https://sepolia-rollup.arbitrum.io/rpc

# ── Etherscan verification (Etherscan V2 multichain) ─────────────
ETHERSCAN_API_KEY=YOUR_ETHERSCAN_API_KEY_HERE
ETHERSCAN_VERIFIER_URL=https://api.etherscan.io/v2/api?chainid=42161

# ── Uniswap v4 — Arbitrum One (chain 42161) ──────────────────────
# Source: https://developers.uniswap.org/contracts/v4/deployments  (verified 2026-04-25)
POOL_MANAGER=0x360e68faccca8ca495c1b759fd9eee466db9fb32
POS_MANAGER=0xd88f38f930b7952f2db2432cb002e7abbf3dd869
# Permit2 is the same on every chain:
PERMIT2=0x000000000022D473030F116dDEE9F6B43aC78BA3

# Uniswap v4 — Arbitrum Sepolia (chain 421614) — testnet
# POOL_MANAGER=0xFB3e0C6F74eB1a21CC1Da29aeC80D2Dfe6C9a317
# POS_MANAGER=0xAc631556d3d4019C95769033B5E719dD77124BAc

# ── Pool Tokens — Arbitrum One: WETH / USDC (native) ─────────────
# WETH (0x82aF...) sorts BELOW USDC (0xaf88...) → WETH = TOKEN0, USDC = TOKEN1
# ASSET_TOKEN = USDC (TOKEN1) because the vault accepts USDC deposits.
TOKEN0=0x82aF49447D8a07e3bd95BD0d56f35241523fBab1
TOKEN1=0xaf88d065e77c8cC2239327C5EDb3A432268e5831
ASSET_TOKEN=0xaf88d065e77c8cC2239327C5EDb3A432268e5831

# ── V2 Pool Params ────────────────────────────────────────────────
# IMPORTANT: V2 uses a fresh PoolKey distinct from the v3-style 0.05%
# WETH/USDC market. Do NOT set TICK_SPACING=10 here — that produces a
# different (V1-era) PoolKey and will not match the deployed V2 hook.
POOL_FEE=500
TICK_SPACING=60

# Active LP range pinned around live ETH price (ticks are USDC-per-WETH;
# adjust at deploy time using TickMath against current sqrtPriceX96).
V2_TICK_LOWER=-199020
V2_TICK_UPPER=-198840

# SQRT_PRICE_X96 — set this to the live price at deploy time.
# Get it from: cast call 0x360e68faccca8ca495c1b759fd9eee466db9fb32 \
#   "getSlot0(bytes32)(uint160,int24,uint24,uint24)" <poolId>
# Or leave blank to default to 1:1 (only correct if deploying a fresh pool).
SQRT_PRICE_X96=

# ── DynamicFeeHookV2 ─────────────────────────────────────────────
# Required by DeployVaultV2.s.sol AND SeedActiveLiquidity.s.sol.
# This is the address produced by HookMiner when you deploy the hook
# (or the address of an already-deployed live hook to reuse).
HOOK=

# ── Treasury ─────────────────────────────────────────────────────
# Receives 20% of hook fees + vault performance fees. Use a Safe multisig.
TREASURY=

# ── Vault Knobs (optional) ────────────────────────────────────────
# PERFORMANCE_FEE_BPS=400      # 4% of yield → treasury (default: 400)
# MAX_TVL=0                    # 0 = unlimited deposit ceiling

# ── Hook Knobs (optional, set via setMaxFeeBps after deploy) ─────
# MAX_FEE_BPS=50               # 0.5% per-swap hook fee cap (hard-cap 1000 = 10%)

# ── Optional Zap (DepositWithZap path) ────────────────────────────
# DeployVaultV2 needs ONE of:
#   ZAP_ROUTER     — address of an ALREADY-DEPLOYED SwapRouter02ZapAdapter
#   SWAP_ROUTER_02 — deploy a fresh adapter wrapping Uniswap SwapRouter02
# Set neither to disable the zap path entirely.
# Uniswap SwapRouter02 on Arbitrum One: 0x68b3465833fb72A70ecDF485E0e4C7bD8665Fc45
# ZAP_ROUTER=
SWAP_ROUTER_02=0x68b3465833fb72A70ecDF485E0e4C7bD8665Fc45
ZAP_POOL_FEE=500

# ── SeedActiveLiquidity inputs (required when seeding LP) ────────
# SEED_AMOUNT0_MAX=            # max WETH (token0) wei to commit
# SEED_AMOUNT1_MAX=            # max USDC (token1) micro-units to commit
# SEED_TICK_LOWER=-199020      # defaults to V2_TICK_LOWER if you omit
# SEED_TICK_UPPER=-198840      # defaults to V2_TICK_UPPER if you omit
# SEED_RECIPIENT=              # mints LP NFT to this address (default: deployer)
# SEED_DEADLINE_SECONDS=300    # mint deadline window

# ── Deprecated / removed ──────────────────────────────────────────
# V2 does NOT deploy a TimelockController. The previously documented
# OWNER + TIMELOCK_DELAY=172800 (48h) flow applied to V1 only.
