{
  "name": "the-pool-keeper",
  "version": "0.1.0",
  "private": true,
  "description": "Off-chain reserve-offer keeper for The Pool. Posts and rebalances VAULT_SPREAD reserve offers on LiquidityVaultV2.",
  "scripts": {
    "keeper:dry": "DRY_RUN=true tsx reserveKeeper.ts",
    "keeper:once": "tsx reserveKeeper.ts",
    "keeper:loop": "LOOP=true tsx reserveKeeper.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "viem": "^2.21.0"
  },
  "devDependencies": {
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "@types/node": "^22.0.0"
  }
}
